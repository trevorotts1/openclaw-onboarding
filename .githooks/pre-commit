#!/bin/bash
# Pre-commit hook: version consistency + fleet QC invariants on every commit.
#
# Gates (all hard-fail, block the commit):
#   1. Client-name guard (CRITICAL — fleet privacy rule, no real names in template)
#   2. WhatsApp fleet ban (FLEET-STANDARDS.md §3 — enabled:true or uncommented WHATSAPP_NUMBER=)
#   3. N28 no destructive cron payloads (rm -rf on install paths / npm uninstall -g openclaw)
#   4. chmod-600 coverage on .sh files that write secrets/.env
#   5. Version consistency (version / install.sh / CHANGELOG.md)
#   6. agent-browser singleton gateway (no raw launch outside browser_manager;
#      teardown+lock+breaker present; sentinel present) — on staged 06-* changes

# ── 0. Locate repo root ──────────────────────────────────────────────────────
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$REPO_ROOT" || exit 1

# ── 1. Client-name guard (CRITICAL) ─────────────────────────────────────────
if [ -f "scripts/qc-assert-no-client-names.sh" ]; then
  if ! bash scripts/qc-assert-no-client-names.sh; then
    echo ""
    echo "PRE-COMMIT BLOCKED: real client names detected in tracked files."
    echo "Replace each with a generic placeholder (see output above)."
    exit 1
  fi
fi

# ── 2. WhatsApp fleet ban ────────────────────────────────────────────────────
WA_FAIL=0
# Staged .json files — check plugins.entries.whatsapp.enabled
while IFS= read -r f; do
  [ -f "$f" ] || continue
  if ! python3 -c "
import json, sys
try:
    d = json.load(open(sys.argv[1]))
    enabled = d.get('plugins',{}).get('entries',{}).get('whatsapp',{}).get('enabled',False)
    sys.exit(1 if enabled else 0)
except Exception: sys.exit(0)
" "$f" 2>/dev/null; then
    echo "PRE-COMMIT BLOCKED: $f has plugins.entries.whatsapp.enabled=true (FLEET-STANDARDS.md §3)"
    WA_FAIL=1
  fi
done < <(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep '\.json$')
# Staged .env files — check for uncommented WHATSAPP_NUMBER=
while IFS= read -r f; do
  [ -f "$f" ] || continue
  if grep -qE '^[[:space:]]*WHATSAPP_NUMBER[[:space:]]*=[^#]' "$f" 2>/dev/null; then
    echo "PRE-COMMIT BLOCKED: $f has uncommented WHATSAPP_NUMBER= (FLEET-STANDARDS.md §3)"
    WA_FAIL=1
  fi
done < <(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep -E '(^|/)\.env$|\.env$')
[ "$WA_FAIL" -eq 1 ] && exit 1

# ── 3. N28 — no destructive cron payloads ───────────────────────────────────
N28_FAIL=0
while IFS= read -r f; do
  [ -f "$f" ] || continue
  # rm -rf on OpenClaw install paths
  if grep -E 'rm[[:space:]]+-rf[[:space:]].*(\~/.openclaw|~/clawd|\$HOME/.openclaw|\$HOME/clawd|/data/.openclaw)' "$f" 2>/dev/null \
      | grep -v '^[[:space:]]*#' | grep -q .; then
    echo "PRE-COMMIT BLOCKED: $f has rm -rf on an OpenClaw install path (N28 violation)"
    N28_FAIL=1
  fi
  # npm uninstall -g openclaw
  if grep -E 'npm[[:space:]]+uninstall[[:space:]]+-g[[:space:]]+openclaw' "$f" 2>/dev/null \
      | grep -v '^[[:space:]]*#' | grep -q .; then
    echo "PRE-COMMIT BLOCKED: $f has npm uninstall -g openclaw (N28 violation)"
    N28_FAIL=1
  fi
  # brew uninstall fleet components
  if grep -E 'brew[[:space:]]+uninstall[[:space:]]+(openclaw|cloudflared)' "$f" 2>/dev/null \
      | grep -v '^[[:space:]]*#' | grep -q .; then
    echo "PRE-COMMIT BLOCKED: $f has brew uninstall of a fleet component (N28 violation)"
    N28_FAIL=1
  fi
done < <(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep '\.sh$')
[ "$N28_FAIL" -eq 1 ] && exit 1

# ── 4. chmod-600 coverage on secrets/.env writers ───────────────────────────
C600_FAIL=0
while IFS= read -r f; do
  [ -f "$f" ] || continue
  if grep -qE '(secrets/\.env|SECRETS_ENV_FILE)' "$f" 2>/dev/null; then
    if ! grep -qE 'chmod[[:space:]]+600' "$f" 2>/dev/null; then
      echo "PRE-COMMIT BLOCKED: $f writes secrets/.env but has no chmod 600 call (token exposure risk)"
      C600_FAIL=1
    fi
  fi
done < <(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep '\.sh$')
[ "$C600_FAIL" -eq 1 ] && exit 1

# ── 6. agent-browser singleton gateway (on staged 06-* / gateway changes) ─────
# SINGLETON POOLED BROWSER — one session, lock=1, TTL, guaranteed teardown,
# reaper backstop. If any staged change touches Skill 06 or the gateway/reaper/
# guard scripts, run the static guard and hard-fail on a regression (raw
# agent-browser launch outside browser_manager.sh, lost teardown/lock/breaker,
# per-iteration session name in a doc, or a missing doctrine sentinel).
if [ -f "scripts/guard-agent-browser-managed.sh" ]; then
  if git diff --cached --name-only --diff-filter=ACM 2>/dev/null \
      | grep -Eq '^(06-ghl-install-pages/|scripts/agent-browser-reaper\.sh|scripts/guard-agent-browser-managed\.sh)'; then
    if ! bash scripts/guard-agent-browser-managed.sh; then
      echo ""
      echo "PRE-COMMIT BLOCKED: agent-browser singleton gateway regression (see output above)."
      echo "Route every agent-browser call through tools/browser_manager.sh; keep its"
      echo "teardown trap + lock + close/state-clear + circuit-breaker; never invent a"
      echo "per-iteration session name; restore the doctrine sentinel to the docs."
      exit 1
    fi
  fi
fi

# ── 7. Persona-set count triad (repo library <-> manifest lockstep) ──────────
# When any persona artifact is staged, the N38 count triad MUST agree in the
# working tree: blueprint dirs == persona-categories.json keys ==
# INDEX-MANIFEST persona_count == canonical_persona_count. A commit that bumps
# one half without the others (the recurring "index advanced, repo library
# lagged" divergence) is blocked HERE, early — long before CI or a roll. Fix by
# running the ONE atomic command: pipeline/publish-personas-to-fleet.sh
PERSONA_GUARD="22-book-to-persona-coaching-leadership-system/pipeline/assert-personas-published.sh"
if [ -f "$PERSONA_GUARD" ]; then
  if git diff --cached --name-only --diff-filter=ACM 2>/dev/null \
      | grep -Eq '^(22-book-to-persona-coaching-leadership-system/personas/|22-book-to-persona-coaching-leadership-system/persona-categories\.json|shared-utils/prebuilt-index/INDEX-MANIFEST\.json)'; then
    if ! bash "$PERSONA_GUARD" --repo-only; then
      echo ""
      echo "PRE-COMMIT BLOCKED: persona-set count triad disagrees (blueprint dirs !="
      echo "persona-categories.json keys != INDEX-MANIFEST persona_count/canonical)."
      echo "A persona was added to one half without the others. Bring all four into"
      echo "lockstep in ONE run before committing:"
      echo "  22-book-to-persona-coaching-leadership-system/pipeline/publish-personas-to-fleet.sh"
      exit 1
    fi
  fi
fi

# ── 5. Version consistency ───────────────────────────────────────────────────
VERSION=$(cat version 2>/dev/null)
INSTALL_VERSION=$(grep 'ONBOARDING_VERSION=' install.sh 2>/dev/null | head -1 | cut -d'"' -f2)
CHANGELOG_VERSION=$(grep -m1 '^\## \[v' CHANGELOG.md 2>/dev/null | sed 's/.*\[//;s/\].*//')

if [ -z "$VERSION" ]; then
  echo "ERROR: version file missing"
  exit 1
fi

if [ "$VERSION" != "$INSTALL_VERSION" ]; then
  echo "ERROR: version ($VERSION) != install.sh ONBOARDING_VERSION ($INSTALL_VERSION)"
  echo "Update install.sh before committing."
  exit 1
fi

if [ "$VERSION" != "$CHANGELOG_VERSION" ]; then
  echo "WARNING: version ($VERSION) != CHANGELOG.md top entry ($CHANGELOG_VERSION)"
  echo "Consider updating CHANGELOG.md before committing."
fi

echo "Version check passed: $VERSION"
echo "Pre-commit QC: all gates passed."
