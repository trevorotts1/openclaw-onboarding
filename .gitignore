# NOTE (v14.10.0): the Skill-6 funnel-matcher catalog index is now COMMITTED. It is
# written PORTABLY (relative root/sourcePath, no system-specific absolute path), so the
# old ignore of 06-ghl-install-pages/tools/catalog-index.json was removed. Rebuild with:
#   python3 06-ghl-install-pages/tools/funnel_matcher_cli.py --build-index

# SQLite runtime artifacts — the persona index (gemini-index.sqlite) is built live
# per box by gemini-indexer.py (or downloaded from GitHub Releases). Never commit
# the DB file or any hot journal / WAL / SHM sidecar that SQLite writes during a
# live write transaction (committing a journal would corrupt the DB on checkout).
*.sqlite
# Exception: committed CI fixtures are tiny schema-only DBs (not runtime artifacts).
!tests/fixtures/*.fixture.sqlite
*-journal
*-wal
*-shm

# ─── Operator-local client roster (real client names) — NEVER commit ──────────
# The no-client-name gates (scripts/qc-assert-no-client-names.sh, the skill
# 38/39/40 qc-no-personal-data.sh gates, 23-ai-workforce-blueprint's how-to and
# presentation-dept-welcome tests, and tests/unit/library-gate-content.test.py)
# load the real roster at runtime from $OPENCLAW_CLIENT_ROSTER or
# ~/.openclaw/client-roster.txt. The real roster must live in NO tracked file.
# Only the committed template (scripts/client-roster.example.txt) is tracked.
client-roster.txt
**/client-roster.txt
.openclaw-client-roster.txt
# Keep the placeholder-only template tracked.
!scripts/client-roster.example.txt
