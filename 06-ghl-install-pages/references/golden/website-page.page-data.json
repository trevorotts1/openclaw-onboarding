  "pageStyles": ":root{ --transparent: transparent;\n--primary: #37ca37;\n--secondary: #188bf6;\n--white: #ffffff;\n--gray: #cbd5e0;\n--black: #000000;\n--red: #e93d3d;\n--orange: #f6ad55;\n--yellow: #faf089;\n--green: #9ae6b4;\n--teal: #81e6d9;\n--malibu: #63b3ed;\n--indigo: #757BBD;\n--purple: #d6bcfa;\n--pink: #fbb6ce;\n--cobalt: #155eef;\n--smoke: #f5f5f5;\n--overlay: rgba(0, 0, 0, 0.5);\n--headlinefont: 'Inter';\n--contentfont: 'Inter';\n--text-color: #000000;\n--link-color: #188bf6; } .bg-fixed{bottom:0;top:0;left:0;right:0;position:fixed;overflow:auto;background-color:var(--white)} \n            \n            .drop-zone-draggable .hl_main_popup{box-shadow:none;padding:20px;margin-top:0;border-color:var(--gray);border-width:10px;border-style:solid;border-radius:0;background-color:var(--white)}\n            \n          \n#hl_main_popup.popup-body{position:absolute!important;left:50%!important;bottom:auto!important;transform:translate(-50%,0)!important;right:auto!important;box-shadow:none;padding:20px;margin-top:0;border-color:var(--gray);border-width:10px;border-style:solid;border-radius:0;background-color:var(--white);width:720px}.--mobile #hl_main_popup.popup-body{width:380px!important}@media screen and (min-width:0px) and (max-width:480px){#hl_main_popup.popup-body{width:380px!important}} \n ",
  "trackingCode": {
    "headerCode": "",
    "footerCode": "<!-- ZHC-FACTORY-WEB-0621 | Riverbend Bread Co. | HOME -->\n<style>\n  .rb-wrap{font-family:Georgia,'Times New Roman',serif;color:#3b2a1a;margin:0;line-height:1.6}\n  .rb-nav{display:flex;justify-content:space-between;align-items:center;padding:18px 6%;background:#fff7ec;border-bottom:2px solid #e3c9a0;flex-wrap:wrap}\n  .rb-brand{font-size:1.5rem;font-weight:bold;color:#8a4b1f;letter-spacing:.5px}\n  .rb-links a{margin-left:26px;text-decoration:none;color:#5a3d23;font-size:1.05rem}\n  .rb-links a:hover{color:#c2691b;text-decoration:underline}\n  .rb-hero{position:relative;min-height:70vh;display:flex;align-items:center;justify-content:center;text-align:center;\n    background:linear-gradient(rgba(40,22,8,.45),rgba(40,22,8,.55)),url('https://assets.cdn.filesafe.space/Mct54Bwi1KlNouGXQcDX/media/576380d8-20b2-491c-9b35-289f6b615dca.png') center/cover no-repeat;color:#fff}\n  .rb-hero h1{font-size:3rem;margin:.2em 0;max-width:14ch}\n  .rb-hero p{font-size:1.35rem;max-width:32ch;margin:.4em auto 1.2em}\n  .rb-cta{display:inline-block;background:#c2691b;color:#fff;padding:16px 38px;border-radius:40px;font-size:1.15rem;\n    text-decoration:none;font-weight:bold;box-shadow:0 6px 18px rgba(0,0,0,.25)}\n  .rb-cta:hover{background:#a9550f}\n  .rb-sec{padding:64px 8%;max-width:1100px;margin:0 auto;text-align:center}\n  .rb-sec h2{font-size:2rem;color:#8a4b1f}\n  .rb-grid{display:flex;gap:28px;flex-wrap:wrap;justify-content:center;margin-top:34px}\n  .rb-card{flex:1 1 240px;max-width:300px;background:#fffaf2;border:1px solid #ecd9bb;border-radius:14px;padding:26px}\n  .rb-card h3{color:#c2691b;margin-top:0}\n  .rb-band{background:#8a4b1f;color:#fff;text-align:center;padding:56px 8%}\n  .rb-band .rb-cta{background:#fff;color:#8a4b1f;margin-top:18px}\n  .rb-foot{background:#3b2a1a;color:#e8d6bf;text-align:center;padding:28px 8%;font-size:.95rem}\n  .rb-foot a{color:#f2c98a;text-decoration:none;margin:0 10px}\n</style>\n<div class=\"rb-wrap\">\n  <nav class=\"rb-nav\">\n    <span class=\"rb-brand\">Riverbend Bread Co.</span>\n    <span class=\"rb-links\"><a href=\"/\">Home</a><a href=\"/about\">About</a><a href=\"/contact\">Contact</a></span>\n  </nav>\n  <header class=\"rb-hero\">\n    <div>\n      <h1>Bread Worth Walking Across Town For</h1>\n      <p>Small-batch sourdough and pastries, baked fresh every morning in your neighborhood.</p>\n      <a class=\"rb-cta\" href=\"/contact\">Reserve a Tasting</a>\n    </div>\n  </header>\n  <section class=\"rb-sec\">\n    <h2>Why Riverbend</h2>\n    <div class=\"rb-grid\">\n      <div class=\"rb-card\"><h3>Naturally Leavened</h3><p>A living sourdough starter, slow-fermented 24 hours for deep flavor and an easy-to-digest crumb.</p></div>\n      <div class=\"rb-card\"><h3>Milled This Week</h3><p>Stone-milled regional grain, never bleached, never rushed. You taste the difference in every slice.</p></div>\n      <div class=\"rb-card\"><h3>Baked at Dawn</h3><p>Out of the oven by 6am, on your table by breakfast. We sell out most days, so come early.</p></div>\n    </div>\n  </section>\n  <section class=\"rb-band\">\n    <h2 style=\"margin-top:0\">Hungry yet?</h2>\n    <p>Book a free in-shop tasting and custom-order consultation.</p>\n    <a class=\"rb-cta\" href=\"/contact\">Reserve a Tasting</a>\n  </section>\n  <footer class=\"rb-foot\">\n    Riverbend Bread Co. &middot; 114 Mill Street &middot; Open Tue&ndash;Sun, 7am&ndash;2pm\n    <div><a href=\"/\">Home</a><a href=\"/about\">About</a><a href=\"/contact\">Contact</a></div>\n  </footer>\n</div>",
