{
  "name": "presentation-intake-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker API for the Presentation department one-question-per-screen client intake mini-app.",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "d1:create": "wrangler d1 create presentation_intake",
    "d1:schema": "wrangler d1 execute presentation_intake --remote --file=schema.sql",
    "test": "node --test ../test/test_worker.mjs"
  },
  "devDependencies": {
    "wrangler": ">=3.60.0"
  }
}
