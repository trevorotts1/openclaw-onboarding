{
  "manifest_version": 3,
  "name": "Convert and Flow Token Grabber",
  "version": "1.0",
  "description": "Grab Firebase refresh token from GoHighLevel for Convert and Flow CLI use",
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "host_permissions": [
    "https://app.convertandflow.com/*",
    "https://app.gohighlevel.com/*",
    "https://*.leadconnectorhq.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png"
    }
  },
  "icons": {
    "48": "icon48.png"
  }
}
