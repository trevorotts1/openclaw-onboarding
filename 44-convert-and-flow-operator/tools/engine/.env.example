# Convert and Flow CLI — canonical credential names
# These go in ~/.openclaw/secrets/.env on your client box.
# The 'caf' / 'convertandflow' / 'ghl' wrapper maps these to GHL_* at runtime.

# --- Required: GoHighLevel public API ---
# Create a Private Integration Token in GHL:
#   Settings -> Private Integrations -> Create New
# Give it every scope you want the CLI to use (contacts, workflows, etc).
GOHIGHLEVEL_API_KEY=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Your GHL location/sub-account ID (the long string in your GHL URL).
GOHIGHLEVEL_LOCATION_ID=YOUR_LOCATION_ID

# Approved location IDs for write operations (comma-separated).
# ENFORCED: writes to any ID not on this list are refused by the safety gate.
# Empty or unset = refuse ALL writes (fail-closed). Set this to your location ID.
GOHIGHLEVEL_ALLOWED_LOCATION_IDS=YOUR_LOCATION_ID

# Set to "true" to create workflow triggers as INACTIVE (active:false).
# Default: true. When true, a workflow trigger won't fire until you activate
# it manually in the GHL UI. Set to "false" only when you intend to go live.
GOHIGHLEVEL_DRAFT_ONLY=true

# Explicit write-approval token for internal API writes (workflow creation).
# Alternatively, prefix your workflow/folder name with ZHC- or ZHC_ for
# standing approval without a token.
CAF_APPROVAL_TOKEN=

# --- Optional but required for workflow creation ---
# The public GHL API can't *create* workflows, only read them.
# To create/update workflows you need a Firebase refresh token.
# Get one with the bundled Chrome extension (Convert and Flow Token Grabber):
#   1. Load chrome-extension/ as an unpacked extension in Chrome
#   2. Open app.convertandflow.com or app.gohighlevel.com while logged in
#   3. Click the extension icon -> "Grab Refresh Token" -> "Copy to Clipboard"
#   4. Paste here:
GOHIGHLEVEL_FIREBASE_REFRESH_TOKEN=

# --- CAF aliases (accepted in addition to GOHIGHLEVEL_* names) ---
# CAF_API_KEY=
# CAF_LOCATION_ID=
# CAF_FIREBASE_REFRESH_TOKEN=
