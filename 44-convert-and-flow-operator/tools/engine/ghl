#!/bin/bash
# Convert and Flow CLI wrapper
# Maps canonical GOHIGHLEVEL_* / CAF_* env vars -> GHL_* at runtime.
# Engine source code stays untouched.
#
# Credential sources (first match wins):
#   1. ~/.openclaw/secrets/.env
#   2. $SECRETS_ENV (override path)
#   3. Already-exported GOHIGHLEVEL_* or GHL_* vars

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VENV_PYTHON="$HOME/.openclaw/tools/convert-and-flow-cli/.venv/bin/python"

# Activate venv (prefer installed venv, fall back to local)
if [ -f "$VENV_PYTHON" ]; then
    source "$HOME/.openclaw/tools/convert-and-flow-cli/.venv/bin/activate"
elif [ -f "$SCRIPT_DIR/.venv/bin/activate" ]; then
    source "$SCRIPT_DIR/.venv/bin/activate"
fi

# Load canonical secrets file
SECRETS_FILE="${SECRETS_ENV:-$HOME/.openclaw/secrets/.env}"
if [ -f "$SECRETS_FILE" ]; then
    set -a
    # shellcheck disable=SC1090
    source "$SECRETS_FILE"
    set +a
fi

# --- Map canonical -> engine names (engine code untouched) ---
# Priority: CAF_ > GOHIGHLEVEL_ > already-set GHL_
export GHL_API_KEY="${CAF_API_KEY:-${GOHIGHLEVEL_API_KEY:-${GHL_API_KEY:-}}}"
export GHL_LOCATION_ID="${CAF_LOCATION_ID:-${GOHIGHLEVEL_LOCATION_ID:-${GHL_LOCATION_ID:-}}}"
export GHL_FIREBASE_REFRESH_TOKEN="${CAF_FIREBASE_REFRESH_TOKEN:-${GOHIGHLEVEL_FIREBASE_REFRESH_TOKEN:-${GHL_FIREBASE_REFRESH_TOKEN:-}}}"

# --- Safety config (passed through env for the safety wrapper layer) ---
# CAF_ALLOWED_LOCATION_IDS: default to the client's own GOHIGHLEVEL_LOCATION_ID when
# neither GOHIGHLEVEL_ALLOWED_LOCATION_IDS nor CAF_ALLOWED_LOCATION_IDS is set.
# Blank defaults = all writes blocked, which is the wrong fail-mode for a single-location install.
_caf_allowed_raw="${GOHIGHLEVEL_ALLOWED_LOCATION_IDS:-${CAF_ALLOWED_LOCATION_IDS:-}}"
if [ -z "$_caf_allowed_raw" ] && [ -n "$GHL_LOCATION_ID" ]; then
    _caf_allowed_raw="$GHL_LOCATION_ID"
    echo "[ghl] Allowed write locations set to ${_caf_allowed_raw}; add more in CAF_ALLOWED_LOCATION_IDS" >&2
fi
export CAF_ALLOWED_LOCATION_IDS="$_caf_allowed_raw"
unset _caf_allowed_raw
export CAF_DRAFT_ONLY="${GOHIGHLEVEL_DRAFT_ONLY:-${CAF_DRAFT_ONLY:-true}}"
export CAF_DRY_RUN="${GOHIGHLEVEL_DRY_RUN:-${CAF_DRY_RUN:-}}"

# Validate required vars
if [ -z "$GHL_API_KEY" ]; then
    echo "ERROR: GOHIGHLEVEL_API_KEY is not set. Add it to $SECRETS_FILE" >&2
    exit 1
fi

exec python3 -m cli_anything.gohighlevel "$@"
