  "skill": "52-avatar-alchemist",
  "description": "Digest-verified DAG of the 40 Avatar-Alchemist generators across 7 subsystems. Single source of truth for aa_director.py (waves, throttle, park/resume) and aa_build_check.py (floors/counts/bands). depends_on is the authoritative dependency wiring (NOT the legacy Make.com module numbering). CLIENT runtime resolves TIER-A/B/SEARCH to the client's OWN providers; ZERO Anthropic ids (G-NOANTHROPIC / AF-AV-NOANTHROPIC).",
  "repairs": {
    "default_state": "on",
    "opt_in_flag": "--apply-repairs",
    "intake_field": "apply_repairs",
    "note": "RATIFIED (R3, 2026-07-05): source anomalies R1-R6 are ON BY DEFAULT for CLIENT runs so a delivered brand package does NOT ship the live workflow's known content bugs (frozen ad category, dead blended-tone compute, empty product/offer line, wrong Solution-Aware pt2 upstream, unused cheat-sheet/Answer-9). The intake (intake/INTAKE-TEMPLATE.md apply_repairs, default true) and aa_intake_gate.py carry the client default; aa_director.py records the effective mode in RUN-LEDGER.json and gates the repair-specific content invariants (e.g. G-ADSET-CAT). Pass aa_director.py --no-repairs (or intake.apply_repairs=false) for a FIDELITY / regression run that is faithful to Trevor's original LIVE workflow output (this is how the golden-lumen-rise-live reference is built). depends_on encodes the repaired scheduling wiring; in a faithful-to-live run the extra upstream artifacts are still computed but the dispatched prompt context follows the live behavior below (dead compute, faithful to source). R7 (the Anthropic ban) is NOT a fidelity repair: it is ALWAYS enforced on every client box (G-NOANTHROPIC) and is NEVER reverted, regardless of the repairs mode.",
    "items": {
      "R1": {
        "stage": "08-blended-tone",
        "live": "receives only the tone-style NAMES; the four tone chains (04-07) are dead compute",
        "repaired": "receives the four tone-style ANALYSIS documents (artifact.04..07)"
      },
      "R2": {
        "stage": "12-solution-aware-pt2",
        "live": "injects the Problem-Aware doc (09) (the source copy-paste bug)",
        "repaired": "injects the Solution-Aware doc (11) and says 'Solution Aware'"
      },
      "R3": {
        "stage": "15-facebook-audiences",
        "live": "the audience_targeting_cheat_sheet tag is empty",
        "repaired": "references the Black CEO Method 7-Tier framework in methodology.md"
      },
      "R4": {
        "stages": "23-34 (ad-set 2..13)",
        "live": "all ad sets freeze on 'category 2'",
        "repaired": "each ad set carries its true restored category signature",
        "gated_invariant": "G-ADSET-CAT / AF-AV-ADSET-CAT (enforced ONLY under --apply-repairs)"
      },
      "R5": {
        "stage": "37-fb-headline-copy",
        "live": "the 'Name of product/offer/mission:' line is empty",
        "repaired": "filled from intake.offer_name / intake.product_info"
      },
      "R6": {
        "stage": "39-hero-page",
        "live": "the Answer-9-Questions output (38) is generated then UNUSED",
        "repaired": "38 feeds the hero page (39 depends_on 38)"
      },
      "R7": {
        "stage": "39-hero-page",
        "always_on": true,
        "rule": "source hardcoded an Anthropic model chain via OpenRouter; re-pointed to the client TIER-A model. The Anthropic chain is removed on every client box and NEVER reverted (client-path rule). G-NOANTHROPIC hard-fails any /anthropic|claude/i id."
      }
    },
    "client_default": "on",
    "fidelity_override_flag": "--no-repairs"
  },
