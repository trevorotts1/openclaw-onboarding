    "contact_id": ["contact_id", "contactId", "contact.id"],
    "location_id": ["location_id", "locationId", "location.id"],
    "podcast_id": ["podcast_id", "podcastId", "podbean_podcast_id", "podbeanPodcastId"],
    "mode": ["mode", "production_mode", "podcast_mode", "podcast_type", "productionMode"],
    "style": ["style", "presentation_style", "writing_style", "podcast_survey_writing_style", "select_your_presentation_style_personal_podcast", "presentationStyle"],
    "preferred_pronoun": ["preferred_pronoun", "my_preferred_pronoun", "pronoun", "pronouns", "preferredPronoun"],
