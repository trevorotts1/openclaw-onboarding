    "explicit": ["explicit", "is_explicit", "explicit_content"],
    "workflow_trigger": ["workflow_trigger", "workflowTrigger"],
    "retry": ["retry", "operator_retry"],
    "_test": ["_test", "test", "is_test", "test_submission"]
  },
  "contact_container_only_aliases": {
    "contact_id": ["id"]
  },
  "enum_normalization": {
    "mode": {
      "personal_podcast_style": ["personal_podcast_style", "personal podcast style", "personal podcast", "personal", "solo", "solo podcast", "own podcast"],
      "interview_style_podcast": ["interview_style_podcast", "interview style podcast", "interview style", "interview", "guest", "guest interview"]
