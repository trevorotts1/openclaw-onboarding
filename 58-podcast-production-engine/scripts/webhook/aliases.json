  "survey_answer_keys_by_style": {
    "_comment": "Populated at onboarding (W1.24 questionnaire wiring, task E1) from PODCAST-SNAPSHOT-BUILD-MANIFEST.md Section A Group 2 (the REAL legacy custom-field create-names, byte-for-byte, double underscore after survey) and cross-checked against config/questionnaires/*.json path_shape.per_style_content_fields and each question's survey_position. Maps a style path (the canonical style token the mapper resolves style to, matching enum_normalization.style) to the ordered list of GHL survey field KEYS (not the Barry/Brene/Dan/Jia internal labels, which never appear in any output); the Nth key fills q<N>_answer positionally.",
    "counter_intuitive": ["podcast_survey__barry_q1", "podcast_survey__barry_q6"],
    "vulnerable": ["podcast_survey__brene_q1", "podcast_survey__brene_q6"],
    "provocative": ["podcast_survey__dan_q1", "podcast_survey__dan_q2", "podcast_survey__dan_q7"],
    "passionate": ["podcast_survey__jia_q1", "podcast_survey__jia_q6", "podcast_survey__jia_q7"]
  }
