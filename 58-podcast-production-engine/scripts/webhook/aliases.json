    "last_name": ["last_name", "lastName", "contact.last_name", "lname"],
    "show_name": ["show_name", "showName", "podcast_name", "show_title", "showTitle"],
    "host_name": ["host_name", "hostName", "host", "guest_first_name", "guestFirstName", "guest_name"],
    "additional_info": ["additional_info", "podcast_survey__additional_info", "additional_information", "additionalInfo"],
    "transparency_answer": ["podcast_interview_smiq", "smiq", "transparency_answer", "podcast_survey_smiq"],
