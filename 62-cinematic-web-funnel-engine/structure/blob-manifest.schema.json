{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openclaw.ai/schemas/cinematic-web-funnel-engine/blob-manifest.schema.json",
  "title": "Cinematic and Web Funnel Engine — blob-manifest.json (Skill 62, U17)",
  "description": "Provenance for scene media uploaded to a Blob-storage adapter (spec executive summary line 13: 'Default media storage: Vercel Blob, with adapter support for Cloudflare R2/S3-compatible storage'). Written by scripts/deploy_vercel.py's upload_scene_media_to_blob(); read/independently re-checked by scripts/prove_deployment.py. Never contains a secret value — the storage token is referenced by NAME only, never by value.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "project_id", "provider", "assets", "created_at", "updated_at"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "project_id": { "type": "string", "minLength": 1 },
    "provider": { "type": "string", "enum": ["vercel-blob", "cloudflare-r2", "s3-compatible"] },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scene_id", "kind", "local_path", "pathname", "url", "content_type", "size_bytes", "uploaded_at"],
        "properties": {
          "scene_id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "enum": ["video", "poster"] },
          "local_path": { "type": "string", "minLength": 1 },
          "pathname": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "minLength": 1, "pattern": "^https://" },
          "content_type": { "type": "string", "minLength": 1 },
          "size_bytes": { "type": "integer", "minimum": 0 },
          "uploaded_at": { "type": "string", "minLength": 1 }
        }
      }
    },
    "created_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 }
  }
}
