{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openclaw.ai/schemas/cinematic-web-funnel-engine/content-manifest.schema.json",
  "title": "Cinematic and Web Funnel Engine — content-manifest.json (Skill 62, U6)",
  "description": "The locked output contract of the content-methodology router (spec Section 7.3). Cinematic assembly may not silently rewrite sacred or approved copy carried in this file; requested changes must return through the owning content methodology (ADR-10).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_id",
    "methodology_source",
    "source_skill",
    "source_skill_version",
    "page_profiles",
    "section_order",
    "approved_copy_paths",
    "cta_map",
    "offer_ledger",
    "conversion_requirements",
    "claims",
    "copy_qc_receipt",
    "content_hash",
    "locked",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "project_id": { "type": "string", "minLength": 1 },
    "methodology_source": {
      "type": "string",
      "enum": ["signature-funnel", "sales-page-assets", "cinematic-native", "existing-funnel-selector"]
    },
    "source_skill": { "type": "string", "minLength": 1 },
    "source_skill_version": { "type": "string", "minLength": 1 },
    "page_profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["profile_id", "sections"],
        "properties": {
          "profile_id": { "type": "string", "minLength": 1 },
          "sections": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "section_order": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "approved_copy_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "cta_map": {
      "type": "object",
      "additionalProperties": true
    },
    "offer_ledger": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "conversion_requirements": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "form": { "type": "boolean" },
        "calendar": { "type": "boolean" },
        "payment": { "type": "boolean" }
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["claim", "truth_source"],
        "properties": {
          "claim": { "type": "string", "minLength": 1 },
          "truth_source": { "type": "string", "minLength": 1 }
        }
      }
    },
    "copy_qc_receipt": {
      "type": "object",
      "additionalProperties": true
    },
    "content_hash": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64,
      "pattern": "^[0-9a-f]{64}$",
      "description": "sha256 hex digest over the canonical (sorted-key) serialization of this manifest's content-bearing fields. Immutable once locked=true."
    },
    "locked": { "type": "boolean" },
    "created_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 }
  }
}
