{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openclaw.ai/schemas/cinematic-web-funnel-engine/intake-questions.schema.json",
  "title": "Cinematic and Web Funnel Engine — intake/questions.json (Skill 62, U9)",
  "description": "The canonical 12-group question bank spec Section 8.1 describes. Validated once at module-load time by scripts/intake_engine.py so a malformed bank fails closed before any question is ever asked.",
  "type": "object",
  "additionalProperties": true,
  "required": ["bank_version", "groups"],
  "properties": {
    "bank_version": { "type": "string", "minLength": 1 },
    "groups": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["slug", "order", "title", "questions"],
        "properties": {
          "slug": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "order": { "type": "integer", "minimum": 1, "maximum": 12 },
          "title": { "type": "string", "minLength": 1 },
          "questions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["id", "order", "type", "required", "prompt"],
              "properties": {
                "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$" },
                "order": { "type": "integer", "minimum": 1 },
                "type": {
                  "type": "string",
                  "enum": ["string", "integer", "number", "boolean", "enum", "list", "claim_list"]
                },
                "enum": { "type": "array", "items": { "type": "string" } },
                "required": { "type": "boolean" },
                "known_context_key": { "type": ["string", "null"] },
                "requires_truth_source": { "type": "boolean" },
                "prompt": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    }
  }
}
