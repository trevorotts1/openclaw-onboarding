# Conversion layer env vars (build unit U16, P12-CRM).
#
# This file documents the NAMING CONVENTION the generated
# `lib/site-data.generated.ts` -> `ctaMap` entries reference by NAME —
# it never contains a real value (spec Section 20: "never log secret
# values"; "record secret presence by name only in receipts"). Populate the
# actual values in the deployment host's own secret store (Vercel project
# env vars), never by committing a filled-in copy of this file.
#
# For each `cta_map[id].embedUrlEnvVar` (kind "ghl-form-embed") — the
# client's GHL-hosted form/calendar widget embed URL, resolved SERVER-SIDE
# only (see components/GhlFormEmbed.tsx for why this must stay off the
# client bundle):
#   GHL_FORM_EMBED_URL_<ID>=
#
# For each `cta_map[id].webhookEnvVar` (kind "ghl-webhook") — the client's
# GHL inbound webhook URL that triggers a Convert and Flow (Skill 44)
# workflow, resolved only inside app/api/conversion-event/route.ts:
#   GHL_WEBHOOK_URL_<ID>=
#
# Names above are illustrative — the actual env var NAME for each CTA is
# whatever the locked content-manifest.json's `cta_map` entry declares.
