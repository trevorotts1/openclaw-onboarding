{
  "_doc": "Model-family -> capability set + default purpose tier. The ONE place modality facts live; both select_model.py (Python, install side) and the Command Center model-selector (TypeScript, runtime side) read this. Capability tokens are the authoritative vocabulary from command-center/src/lib/model-registry-types.ts :: MODEL_CAPABILITIES. A model is matched to a family by the first regex in `families` whose `match` matches the (provider-stripped) model id. Version-agnostic on purpose: qwen3-vl matches any qwen3-vl* slug regardless of size/version.",
  "_version": "1.0.0",
  "_capability_vocabulary": [
    "text", "embeddings", "image_generation", "video_generation",
    "audio_generation", "audio_transcription", "vision", "audio_input",
    "streaming", "reasoning", "tool_use", "structured_output",
    "long_context", "code_execution", "web_search", "computer_use"
  ],
  "families": [
    {
      "family": "deepseek-pro",
      "match": "deepseek-v[0-9.]+-pro",
      "capabilities": ["text", "reasoning", "tool_use", "structured_output", "long_context", "streaming"],
      "default_tier": "heavy"
    },
    {
      "family": "deepseek-flash",
      "match": "deepseek-v[0-9.]+-flash",
      "capabilities": ["text", "tool_use", "structured_output", "streaming"],
      "default_tier": "fast"
    },
    {
      "family": "kimi",
      "match": "kimi-k[0-9.]+",
      "capabilities": ["text", "reasoning", "tool_use", "structured_output", "long_context", "streaming"],
      "default_tier": "heavy"
    },
    {
      "family": "qwen-vl",
      "match": "qwen[0-9.]*-vl",
      "capabilities": ["text", "vision", "reasoning", "tool_use", "structured_output", "streaming"],
      "default_tier": "heavy"
    },
    {
      "family": "qwen",
      "match": "qwen[0-9.]*(?:-(?:coder|max|plus|turbo))?",
      "capabilities": ["text", "reasoning", "tool_use", "structured_output", "long_context", "streaming"],
      "default_tier": "mid"
    },
    {
      "family": "minimax",
      "match": "minimax-m[0-9.]+",
      "capabilities": ["text","vision","reasoning","tool_use","structured_output","long_context","streaming"],
