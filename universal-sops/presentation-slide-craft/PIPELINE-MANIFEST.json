{
  "manifest_version": 9,
  "$schema_note": "SINGLE SOURCE OF TRUTH for the Presentations department pipeline. Build-time lockstep (scripts/sync_check.py) validates build_deck.py + the MASTER-QC-AUTOFAIL-RULESET.md Section-5 table + the role-library/sops dirs against THIS file, in BOTH directions. Editing this file is step (i) of SOP-SLIDE-06-EXTENSION-AND-SYNC; every other lockstep artifact is validated against it. SOP-LOCKED: any added/changed SOP, role, or gate MUST update this manifest (and bump manifest_version), add a build_deck.py preflight entry/checker, add the AF code to the MASTER ruleset, and add a test. sync_check.py FAILS the QC gate / commit / onboarding update if any of those four is skipped.",
  "deliverables_required": [
    {
      "key": "deck_pptx",
      "filename": "{deck_slug}-FINAL.pptx",
      "label": "assembled deck PPTX",
      "min_bytes": 1048576,
      "note": ">1MB floor; a sub-1MB pptx implies empty/placeholder content"
    },
    {
      "key": "deck_pdf",
      "filename": "{deck_slug}-FINAL.pdf",
      "label": "deck PDF export",
      "min_bytes": 51200,
      "note": ">50KB; produced by PPTX Assembly Specialist"
    },
    {
      "key": "guide_pdf",
      "filename": "PRESENTER-GUIDE.pdf",
      "label": "presenter guide PDF",
      "min_bytes": 51200,
      "note": ">50KB; produced by Presenters Guide Specialist. REQUIRED UPSTREAM STEP."
    },
    {
      "key": "speech_md",
      "filename": "PRESENTERS-SPEECH.md",
      "label": "presenter speech markdown source (pure)",
      "min_bytes": 2048,
      "note": ">2KB; produced by Presenters Speech Writer (pure script). REQUIRED UPSTREAM STEP."
    },
    {
      "key": "speech_pdf",
      "filename": "PRESENTERS-SPEECH.pdf",
      "label": "presenter speech teleprompter PDF",
      "min_bytes": 20480,
      "note": ">20KB; produced by Presenters Speech Writer (teleprompter PDF render). REQUIRED UPSTREAM STEP."
    },
    {
      "key": "speech_fish_md",
      "filename": "PRESENTERS-SPEECH-FISH-TAGGED.md",
      "label": "presenter speech (Fish-Audio expression-tagged)",
      "min_bytes": 2048,
      "note": ">2KB; the (break)/(laugh)/emphasis-tagged script that feeds the audio render. Produced by Presenters Speech Writer / Fish Audio Expression Specialist. REQUIRED UPSTREAM STEP."
    },
    {
      "key": "audio_mp3",
      "filename": "PRESENTER-AUDIO.mp3",
      "label": "presenter audio MP3",
      "min_bytes": 512000,
      "note": ">500KB; produced by Audio Demonstration Specialist. REQUIRED UPSTREAM STEP."
    },
    {
      "key": "infographic_png",
      "filename": "infographic.png",
      "label": "infographic checklist PNG",
      "min_bytes": 102400,
      "note": ">100KB; one-page infographic slide exported as PNG. Owned by slide-image-creator (SOP: slide-image-creator-sops.md infographic step) with final PNG export by pptx-assembly-specialist (SOP: pptx-assembly-specialist-sops.md infographic export step). REQUIRED UPSTREAM STEP.",
      "owning_role": "slide-image-creator",
      "export_role": "pptx-assembly-specialist"
    },
    {
      "key": "teleprompter_html",
      "filename": "presenter-teleprompter.html",
      "label": "presenter teleprompter web app",
      "min_bytes": 10240,
      "note": ">10KB; the standalone scrolling teleprompter app (HTML + inline CSS/JS). Produced by build_teleprompter.py (teleprompter role). REQUIRED UPSTREAM STEP."
    }
  ],
  "phases": [
    {
      "id": "P-0.5-RESEARCH",
      "order": -0.5,
      "name": "Deep Research",
      "owning_role": "deep-research-specialist-presentations",
      "sop_refs": [
        "deep-research-specialist-presentations-sops.md"
      ],
      "produces_artifact": "working/research/brief-*.md",
      "gate_codes": [
        "AF-RESEARCH-GATE",
        "AF-RESEARCH-UNCITED"
      ],
      "preflight": {
        "required": true,
        "checker": "_chk_research_brief",
        "label": "research brief (research_complete:true)"
      },
      "additional_preflights": [
        {
          "required": true,
          "checker": "_chk_research_cited",
          "label": "research pack cited URLs (>= MIN_CITED_SOURCES distinct http(s) URLs; AF-RESEARCH-UNCITED)"
        },
        {
          "required": true,
          "checker": "_chk_claims_without_citation",
          "label": "claims-without-citation (slide copy claim markers must have a cited research pack; AF-RESEARCH-UNCITED)"
        }
      ],
      "required_brief_categories": [
        {"code": "A", "name": "Niche Deck Structures", "hard_gate": true, "note": "Best-in-class deck structure patterns for the niche; always required"},
        {"code": "B", "name": "Pricing & Value Benchmarking", "hard_gate": false, "note": "Comparable-market price band (low/median/high); checked by Offer Price Strategist and AF-CONVERTER-PARITY gate"},
        {"code": "C", "name": "Supporting Statistics / Studies / White Papers", "hard_gate": true, "note": "Every stat must carry a source URL + publication date; stale >36 months flagged"},
        {"code": "D", "name": "External Corroboration (GP-8: who says so other than you?)", "hard_gate": true, "note": "D1=named expert quotes, D2=third-party case studies, D3=Wall-of-Wins testimonials; zero HIGH/MEDIUM triggers GP-8 ALERT"},
        {"code": "E", "name": "Grounded Image Context", "hard_gate": false, "note": "Scene descriptions anchoring Kie/GPT-Image-2 renders to THIS source's method; checked by Gate 5 and AF-CONVERTER-PARITY gate"},
        {"code": "F", "name": "Design + Hook + Pacing Best-Practices Research", "hard_gate": true, "note": "Design-brief input for Typography Architect and Slide Image Creator; may be skipped only with design_research_mode: delegated_to_DIU + logged delegation note"},
        {"code": "G", "name": "Credible Attributable Quotes", "hard_gate": true, "note": "Named, sourced, verbatim quotes for 'who says so' slides; routed to Slide Copywriter"},
        {"code": "H", "name": "Fact-Validation — Slide-Claim Verification Ledger", "hard_gate": true, "note": "Every slide-bound figure verified; produces fact-validation ledger; routed to QC + Slide Copywriter"},
        {"code": "I", "name": "Objection Research", "hard_gate": true, "note": "Audience objections with proof rebuttals; routed to Slide Copywriter + Devil's Advocate"},
        {"code": "J", "name": "Social-Proof Patterns", "hard_gate": false, "note": "Social-proof formats and platforms; required-but-may-be-condensed; routed to Slide Copywriter"},
        {"code": "K", "name": "Persuasion-Framework Validation", "hard_gate": true, "note": "Arc validation against proven structures; routed to Director + Slide Copywriter"},
        {"code": "L", "name": "Compliance Flags", "hard_gate": true, "note": "Income claims, health claims, regulatory risks; routed to Director + Devil's Advocate"}
      ]
    },
    {
      "id": "P-CONVERTER",
      "order": -1,
      "name": "Content-to-Presentation Conversion (Zoom/Video/Doc → Intake)",
      "owning_role": "content-to-presentation-architect",
      "sop_refs": [
        "content-to-presentation-architect-sops.md"
      ],
      "produces_artifact": "working/copy/intake.json",
      "gate_codes": [
        "AF-CONVERTER-PARITY"
      ],
      "preflight": null,
      "routing_note": "Content-first path only. Writes intake.json with source_brief_origin: 'content-to-presentation-architect'. Mandates Phase -0.5 Deep Research (SOP 9.8 step 3) before standard pipeline continues.",
      "converter_path": true
    },
    {
      "id": "P0A-INTAKE",
      "order": 0.1,
      "name": "Intake / Interview Confirm",
      "owning_role": "director-of-presentations",
      "sop_refs": [
        "director-of-presentations-sops.md"
      ],
      "produces_artifact": "working/copy/intake.json",
      "gate_codes": [],
      "preflight": {
        "required": true,
        "checker": "_chk_intake",
        "label": "intake.json (interview_confirmed:true, presentation_mode one-person|general)"
      }
    },
    {
      "id": "P1Q-COPY-QC",
      "order": 1.5,
      "name": "Copy QC (Phase 1Q)",
      "owning_role": "qc-specialist-presentations",
      "sop_refs": [
        "qc-specialist-presentations-sops.md"
      ],
      "produces_artifact": "working/qc/copy_qc_report.json",
      "gate_codes": [
        "AF-HOOK-1",
        "AF-HOOK-2",
        "AF-HOOK-3",
        "AF-HOOK-4",
        "AF-HOOK-5",
        "AF-HOOK-7",
        "AF-AUD-1",
        "AF-AUD-2",
        "AF-AUD-3",
        "AF-AUD-4",
        "AF-AUD-5",
        "AF-OBI-1",
        "AF-OBI-2",
        "AF-OBI-3",
        "AF-OBI-4",
        "AF-OBI-5",
        "AF-DEN-1",
        "AF-DEN-2",
        "AF-DEN-3",
        "AF-DEN-4",
        "AF-DEN-5",
        "AF-DEN-6",
        "AF-DEN-7",
        "AF-DEN-8",
        "AF-QC-INDEPENDENCE"
      ],
      "preflight": {
        "required": true,
        "checker": "_chk_copy_qc",
        "label": "copy QC report (gate Phase 1Q, average >= 8.5, no AF-* triggered, independent-reviewer provenance)"
      }
    },
    {
      "id": "P3-ARC",
      "order": 3,
      "name": "Converting Arc Allocation",
      "owning_role": "offer-price-strategist",
      "sop_refs": [
        "offer-price-strategist-sops.md"
      ],
      "produces_artifact": "working/copy/arc_allocation.json",
      "gate_codes": [
        "AF-COVERAGE-1"
      ],
      "preflight": {
        "required": true,
        "checker": "_chk_arc",
        "label": "converting arc \u2014 per-slide arc-section allocation"
      }
    },
    {
      "id": "P4-COPY",
      "order": 4,
      "name": "Slide Copy",
      "owning_role": "slide-copywriter",
      "sop_refs": [
        "slide-copywriter-sops.md"
      ],
      "produces_artifact": "working/copy/slides_copy.md",
      "gate_codes": [
        "AF-OBI-6"
      ],
      "preflight": {
        "required": true,
        "checker": "_chk_slides_copy",
        "label": "slide copy authored per doctrine (hook >=7x, 10 components)"
      }
    },
    {
      "id": "PF-DESIGN",
      "order": 4.5,
      "name": "Typography / Design Brief",
      "owning_role": "typography-architect",
      "sop_refs": [
        "typography-architect-sops.md"
      ],
      "produces_artifact": "working/research/design-brief-*.md",
      "gate_codes": [],
      "preflight": {
        "required": true,
        "checker": "_chk_design_brief",
        "label": "typography/design brief \u2014 per-slide creative art direction"
      }
    },
    {
      "id": "P4-RENDER",
      "order": 4.9,
      "name": "Deterministic Render (build_deck.py \u2014 this script)",
      "owning_role": "slide-image-creator",
      "sop_refs": [
        "slide-image-creator-sops.md"
      ],
      "produces_artifact": "renders/slide-*.png",
      "gate_codes": [
        "AF-P1",
        "AF-P2",
        "AF-R3",
        "AF-PLACEHOLDER",
        "AF-RENDERER",
        "AF-MODEL-SOVEREIGNTY",
        "AF-NO-VISION-QC",
        "AF-I14"
      ],
      "preflight": null,
      "emits": {
        "self": true,
        "checks": [
          "PROMPT_CHAR_FLOOR",
          "PROMPT_CHAR_CEILING",
          "FORBIDDEN_DEMOGRAPHIC_DEFAULTS"
        ]
      }
    },
    {
      "id": "P8-ASSEMBLE",
      "order": 8,
      "name": "PPTX Assembly",
      "owning_role": "pptx-assembly-specialist",
      "sop_refs": [
        "pptx-assembly-specialist-sops.md"
      ],
      "produces_artifact": "*-FINAL.pptx",
      "gate_codes": [
        "AF-CONVERTER-PARITY"
      ],
      "preflight": null,
      "emits": {
        "self": true,
        "checks": [
          "parse_speech_chunks"
        ]
      }
    },
    {
      "id": "P9-SPEECH",
      "order": 8.5,
      "name": "Presenter Speech (length gate)",
      "owning_role": "presenters-speech-writer",
      "sop_refs": [
        "presenters-speech-writer-sops.md"
      ],
      "produces_artifact": "working/presenter-speech/PRESENTER-SPEECH.md",
      "gate_codes": [
        "AF-SPEECH-SHORT"
      ],
      "preflight": {
        "required": false,
        "checker": "_chk_speech_length",
        "label": "speech length — presenter speech words >= target_talk_minutes x 120 wpm (fails short; defers when speech absent)"
      }
    },
    {
      "id": "P9-DELIVER",
      "order": 9,
      "name": "Delivery Interlock + Postflight Completeness Gate",
      "owning_role": "delivery-concierge",
      "sop_refs": [
        "delivery-concierge-sops.md"
      ],
      "produces_artifact": "working/delivery/PRESENTER-AUDIO.mp3",
      "gate_codes": [
        "AF-BUNDLE-COMPLETE",
        "AF-DELIVER",
        "AF-DH1",
        "AF-DELIVERY-COMPLETE",
        "AF-I14"
      ],
      "preflight": null
    }
  ],
  "autofails": [
    {
      "code": "AF-P1",
      "stage": "Render",
      "level": "slide",
      "in_ruleset": false,
      "trigger": "rich prompt missing or under the 1500-char floor",
      "enforced_by": "build_deck",
      "py_symbol": "_chk_rich_prompts"
    },
    {
      "code": "AF-P2",
      "stage": "Render",
      "level": "slide",
      "in_ruleset": false,
      "trigger": "composed prompt over the 18000 ceiling",
      "enforced_by": "build_deck",
      "py_symbol": "PROMPT_CHAR_CEILING"
    },
    {
      "code": "AF-R3",
      "stage": "Render",
      "level": "slide",
      "in_ruleset": false,
      "trigger": "hardcoded demographic default in the slide spec (60/30/10 landmine)",
      "enforced_by": "build_deck",
      "py_symbol": "FORBIDDEN_DEMOGRAPHIC_DEFAULTS"
    },
    {
      "code": "AF-RESEARCH-GATE",
      "stage": "1Q",
      "level": "DECK",
      "in_ruleset": false,
      "trigger": "research_complete not true",
      "enforced_by": "build_deck",
      "py_symbol": "_chk_research_brief"
    },
    {
      "code": "AF-RESEARCH-UNCITED",
      "stage": "-0.5/1Q",
      "level": "DECK",
      "in_ruleset": true,
      "trigger": "research pack contains fewer than MIN_CITED_SOURCES (8) distinct http(s) URLs, OR slide copy contains factual/statistical claim markers with zero cited URLs in the research pack — the self-asserted research_complete:true flag is ignored; real citations are required",
      "enforced_by": "build_deck",
      "py_symbol": "_chk_research_cited",
      "secondary_py_symbols": ["_chk_claims_without_citation", "MIN_CITED_SOURCES"]
    },
    {
      "code": "AF-COVERAGE-1",
      "stage": "1Q/6",
      "level": "DECK",
      "in_ruleset": true,
      "trigger": "output deck has fewer slides than the client source deck (Mode B add-only)",
      "enforced_by": "build_deck",
      "py_symbol": "_chk_coverage"
    },
    {
      "code": "AF-BUNDLE-COMPLETE",
      "stage": "Done",
      "level": "DECK",
      "in_ruleset": false,
      "trigger": "postflight completeness gate \u2014 one or more required deliverables missing or below size threshold",
      "enforced_by": "build_deck",
      "py_symbol": "run_postflight_gate"
    },
    {
      "code": "AF-SPEECH-SHORT",
      "stage": "9",
      "level": "DECK",
      "in_ruleset": false,
      "trigger": "presenter speech word count below target_talk_minutes x 120 wpm floor",
      "enforced_by": "build_deck",
      "py_symbol": "_chk_speech_length"
    },
    {
      "code": "AF-DELIVER",
      "stage": "Done",
      "level": "DECK",
      "in_ruleset": false,
      "trigger": "delivery interlock \u2014 six-file bundle not assembled",
      "enforced_by": "closeout_gate",
      "py_symbol": null
    },
    {
      "code": "AF-DH1",
      "stage": "Done",
      "level": "DECK",
      "in_ruleset": false,
      "trigger": "delivery human-handoff gate not satisfied",
      "enforced_by": "closeout_gate",
      "py_symbol": null
